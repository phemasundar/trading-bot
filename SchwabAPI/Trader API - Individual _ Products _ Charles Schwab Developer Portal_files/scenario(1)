ConfirmitHelper.snapTicketMinimizer = function () {

	// Set up the MutationObserver to watch the body element
	const observer = new MutationObserver((mutations) => {
		mutations.forEach((mutation) => {
			if (mutation.type === "attributes" && mutation.attributeName === "class") {
				if (document.body.classList.contains("snapticket-open")) {
					console.log("Run minimize");
					ConfirmitHelper.fbminize();

					document.querySelectorAll(".cfdfmodel1").forEach(element => {
    				element.remove();
					});
				}
			}
		});
	});

	// Start observing the <body> element
	observer.observe(document.body, {
		attributes: true, // Watch for attribute changes
		attributeFilter: ["class"], // Only observe class changes
		subtree: false // Do not observe child elements
	});

}

