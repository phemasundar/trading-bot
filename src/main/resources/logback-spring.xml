<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATH" value="logs" />
    <property name="LOG_FILE" value="trading-bot" />

    <!-- Console Appender (INFO and above for main app) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %c{1} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender (main app log) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover with size-based triggering -->
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}-%d{yyyy-MM-dd}-%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>10</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %c{1} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ══════════════════════════════════════════════════════════════
         PERF: Dedicated performance timing file appender.
         Receives output ONLY from PerformanceLogger (logger configured below).
         Output: logs/trading-bot-perf.log
         To disable all PERF output: set the PerformanceLogger level to OFF.
         ══════════════════════════════════════════════════════════════ -->
    <appender name="PERF_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/trading-bot-perf.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/trading-bot-perf-%d{yyyy-MM-dd}-%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>5</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- PERF console mirror — comment out the appender-ref below to silence PERF from console -->
    <appender name="PERF_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [PERF] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- PerformanceLogger: routes EXCLUSIVELY to PERF appenders.
         Set level="OFF" here to completely disable all performance timing output.
         additivity="false" ensures these lines never appear in the main log file. -->
    <logger name="com.hemasundar.utils.PerformanceLogger" level="DEBUG" additivity="false">
        <appender-ref ref="PERF_FILE" />
        <appender-ref ref="PERF_CONSOLE" />
    </logger>

    <!-- Project Loggers -->
    <logger name="com.hemasundar" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <logger name="com.hemasundar.apis" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
